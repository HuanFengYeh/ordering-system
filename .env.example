# 複製成 .env 後填入實際值（.env 已被 gitignore，不會上傳）

# PostgreSQL 連線字串
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
# 直連（migration 用）。Neon 上填不含 -pooler 的字串；本機可與 DATABASE_URL 相同
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# 櫃檯後台登入密碼（務必改掉）
ADMIN_PASSWORD="change-me"
# session cookie 秘密值，用 `openssl rand -hex 32` 產生
AUTH_SECRET="change-me-to-a-long-random-hex"

# 出單方式：browser（預設）/ cloudprnt（雲端出單機）/ both
PRINT_MODE="browser"
# 收據紙寬對應半形字元數：80mm≈48、58mm≈32
PRINT_COLS="48"
# 未結帳訂單自動作廢的分鐘數（預設 10）
ORDER_EXPIRE_MINUTES="10"
# 老闆 PIN：收班頁與營業額需輸入這組才看得到（員工看不到）。務必設定
OWNER_PIN="change-me"
# 選用：CloudPRNT 端點保護金鑰
# CLOUDPRNT_KEY=""
# 正式網址（QR 與連結才正確），例：https://juju-order.vercel.app
# PUBLIC_BASE_URL=""
